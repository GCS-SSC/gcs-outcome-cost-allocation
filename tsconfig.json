{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "types": [
      "vitest/globals"
    ],
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": [
    "components/**/*.vue",
    "env.d.ts",
    "extension.config.ts",
    "server/**/*.ts",
    "shared/**/*.ts",
    "tests/**/*.ts"
  ]
}
